# =============================================
# BANKING HELPDESK — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# Never commit .env to git

# --- Database (Neon PostgreSQL) ---
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- Pinecone Vector Store ---
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY="your-pinecone-api-key"
# Your index name (create a free index at pinecone.io, dimension=1536 for OpenAI)
PINECONE_INDEX="banking-helpdesk"

# --- Embedding Provider ---
# Choose: "openai" or "huggingface"
EMBEDDING_PROVIDER="openai"

# --- OpenAI (for embeddings) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# --- HuggingFace (alternative embeddings) ---
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY="hf_..."

# --- Groq (for LLM inference - free tier available) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY="gsk_..."

# --- Server ---
PORT=3000
NODE_ENV=development

# --- CORS (your frontend URL) ---
# Local dev: http://localhost:3001
# Vercel deploy: https://your-app.vercel.app
ALLOWED_ORIGIN="http://localhost:3001"
